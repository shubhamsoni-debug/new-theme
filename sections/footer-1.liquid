                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fbc059" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-mail"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
            </li>
          {% endif %}
          {% if section.settings.address != blank %}
            <li>
              <span class="cars-part-footer__mini-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fbc059" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-map-pin"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <span>{{ section.settings.address }}</span>
            </li>
          {% endif %}
        </ul>
      </div>

      <!-- Quick Links -->
      <div class="cars-part-footer__col cars-part-footer__links">
        <h3 class="cars-part-footer__heading">
          {% comment %} <span class="cars-part-footer__heading-icon">🔗</span> {% endcomment %}
          <span>Quick <em>Links</em></span>
        </h3>

        <div class="cars-part-footer__line"></div>

        {% if footer_menu_1 != blank %}
          <ul class="cars-part-footer__link-list">
            {% for link in linklists[footer_menu_1].links %}
              <li>
                <a href="{{ link.url }}">
                  {% comment %} <span class="cars-part-footer__arrow">›</span> {% endcomment %}
                  <span>{{ link.title }}</span>
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      <!-- Shopping Info -->
      <div class="cars-part-footer__col cars-part-footer__links cars-part-footer__shopping">
        <h3 class="cars-part-footer__heading">
          {% comment %} <span class="cars-part-footer__heading-icon">
            <svg width="24px" height="24px" viewBox="0 0 1024 1024" class="icon" version="1.1" xmlns="http://www.w3.org/2000/svg" fill="#000000"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><path d="M916.5 334.5v101.7c0 24.9-27.3 45.2-60.8 45.2h-2.4v-12.9h2.4c24 0 43.4-14.5 43.4-32.4V334.5c0-17.8-19.4-32.4-43.4-32.4H517.1c-0.4-3.1-0.7-5.7-1-7.8l2 0.2-0.1-2c7.7-0.9 15-2 22-3.3h315.8c33.4 0.1 60.7 20.4 60.7 45.3z" fill="#FF6EA9"></path><path d="M899.1 334.5v101.7c0 17.8-19.4 32.4-43.4 32.4H604v12.8h237v358.3c0 16.9-13.7 30.6-30.6 30.6h-604c-16.9 0-30.6-13.7-30.6-30.6V481.4h332.6v-12.8l29.3-6.4c11 33.7 25.2 63.6 42.8 79.6l-8.1 71.5 121.9 162 96.7-82.5-120.4-146-81-13.3c-45.2-39.5-67-185.8-72.6-231.4h338.6c24.1 0 43.5 14.6 43.5 32.4z" fill="#FFE843"></path><path d="M853.3 481.4v358.3c0 23.6-19.2 42.8-42.8 42.8h-604c-23.6 0-42.8-19.2-42.8-42.8V481.4h12.2v358.3c0 16.9 13.7 30.6 30.6 30.6h604c16.9 0 30.6-13.7 30.6-30.6V481.4h12.2z" fill="#FF6EA9"></path><path d="M841.1 469.6h12.2v11.9h-12.2z" fill="#FF6EA9"></path><path d="M853.3 468.6v1h-12.2v11.8H604v-12.8z" fill="#FF6EA9"></path><path d="M670.8 546.8l120.4 146-96.7 82.5-121.9-162 8.1-71.5c-17.6-16-31.8-45.8-42.8-79.6-19.7-59.8-29.7-131.7-33.2-160.1h12.5c5.6 45.6 27.4 191.9 72.6 231.4l81 13.3z m103.3 144.5L664.3 558.2l-71.9-11.9-7.1 63.6 111.1 147.7 77.7-66.3z" fill="#CE1B6D"></path><path d="M664.3 558.2l109.8 133.1-77.7 66.3-111.1-147.7 7.1-63.5z" fill="#D66474"></path><path d="M674.2 125c17.8 25.9 20.7 58.2 7.3 86.5-0.7 2.1-23.5 57-141.6 77.7h-22.1l-0.4-10.3c127.3-16.6 151.2-72.4 151.5-72.9 11.4-24.3 9.2-51.6-6-73.5-16-23.5-44.3-36.9-76.3-36.9-2.9 0-5.7 0.1-8.7 0.4-17.4 1.2-31.3 8.1-41.4 20.3-18.2 22-21.1 56.4-21.1 75.9 0-13-1.2-32-7-50.5 3.7-12.1 9.3-24.1 17.6-34.1 12.7-15.2 29.8-23.7 51-25.3 40.5-2.9 76.9 13.1 97.2 42.7z" fill="#CE1B6D"></path><path d="M662.9 132.7c15.2 21.9 17.4 49.1 6 73.5-0.2 0.5-24.2 56.