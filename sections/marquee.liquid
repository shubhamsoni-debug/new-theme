{% liquid
  assign marquee_direction = section.settings.direction
%}

<section
  id="marquee-{{ section.id }}"
  class="infinite-marquee-section direction-{{ marquee_direction }}"
  aria-label="{{ section.settings.aria_label | escape }}"
  style="
    --marquee-bg: {{ section.settings.bg_color }};
    --marquee-text: {{ section.settings.text_color }};
    --marquee-accent: {{ section.settings.accent_color }};
    --marquee-padding-top: {{ section.settings.padding_top }}px;
    --marquee-padding-bottom: {{ section.settings.padding_bottom }}px;
    --marquee-margin-top: {{ section.settings.margin_top }}px;
    --marquee-margin-bottom: {{ section.settings.margin_bottom }}px;
    --marquee-item-gap: {{ section.settings.item_gap }}px;
    --marquee-font-size: {{ section.settings.font_size }}px;
    --marquee-speed: {{ section.settings.speed }}s;
  "
>
  <div class="infinite-marquee-section__inner">
    {% if section.settings.heading != blank %}
      <h2 class="infinite-marquee-section__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="infinite-marquee" role="region" aria-label="{{ section.settings.aria_label | escape }}">
      <div class="infinite-marquee__track">
        {% for i in (1..2) %}
          <div class="infinite-marquee__group">
            {% for block in section.blocks %}
              <div class="infinite-marquee__item" {{ block.shopify_attributes }}>
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}" class="infinite-marquee__link">
                {% endif %}

                <div class="infinite-marquee__content">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 300 }}"
                      alt="{{ block.settings.alt | escape }}"
                      class="infinite-marquee__image"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  {% endif %}

                  {% if block.settings.svg_code != blank %}
                    <span class="infinite-marquee__svg">
                      {{ block.settings.svg_code }}
                    </span>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <span class="infinite-marquee__text">{{ block.settings.text }}</span>
                  {% endif %}
                </div>

                {% if block.settings.link != blank %}
                  </a>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
.infinite-marquee-section {
  background: var(--marquee-bg);
  margin-top: var(--marquee-margin-top);
  margin-bottom: var(--marquee-margin-bottom);
  padding-top: var(--marquee-padding-top);
  padding-bottom: var(--marquee-padding-bottom);
  overflow: hidden;
  position: relative;
}

.infinite-marquee-section__heading {
  margin: 0 0 18px;
  color: var(--marquee-text);
  font-size: calc(var(--marquee-font-size) + 6px);
  text-align: center;
  line-height: 1.2;
}

.infinite-marquee {
  overflow: hidden;
  position: relative;
  width: 100%;
  mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
}

.infinite-marquee::before,
.infinite-marquee::after {
  content: "";
  position: absolute;
  top: 0;
  width: 70px;
  height: 100%;
  pointer-events: none;
  z-index: 2;
}

.infinite-marquee::before {
  left: 0;
  background: linear-gradient(to right, var(--marquee-bg), transparent);
}

.infinite-marquee::after {
  right: 0;
  background: linear-gradient(to left, var(--marquee-bg), transparent);
}

.infinite-marquee__track {
  display: flex;
  width: max-content;
  will-change: transform;
  animation: marquee-loop var(--marquee-speed) linear infinite;
}

.infinite-marquee__group {
  display: flex;
  align-items: center;
  gap: var(--marquee-item-gap);
  padding-right: var(--marquee-item-gap);
  flex-shrink: 0;
}

.infinite-marquee__item {
  flex-shrink: 0;
  white-space: nowrap;
}

.infinite-marquee__link {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  color: inherit;
}

.infinite-marquee__content {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  color: var(--marquee-text);
  font-size: var(--marquee-font-size);
  line-height: 1.2;
}

.infinite-marquee__text {
  color: var(--marquee-text);
  font-size: inherit;
  line-height: 1.2;
}

.infinite-marquee__image {
  display: block;
  height: 42px;
  width: auto;
  object-fit: contain;
  flex-shrink: 0;
}

.infinite-marquee__svg {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--marquee-accent);
  flex-shrink: 0;
}

/*.infinite-marquee__svg svg {
  width: auto;
  height: 42px;
  display: block;
  fill: currentColor;
}*/

.direction-right .infinite-marquee__track {
  animation-direction: reverse;
}

.direction-left .infinite-marquee__track {
  animation-direction: normal;
}

@keyframes marquee-loop {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

@media (max-width: 749px) {
  .infinite-marquee-section__heading {
    font-size: calc(var(--marquee-font-size) + 2px);
  }

  .infinite-marquee::before,
  .infinite-marquee::after {
    width: 40px;
  }

  .infinite-marquee__content {
    gap: 8px;
    font-size: calc(var(--marquee-font-size) - 1px);
  }

  /*.infinite-marquee__image,
  .infinite-marquee__svg svg {
    height: 30px;
  }*/
}

@media (prefers-reduced-motion: reduce) {
  .infinite-marquee__track {
    animation: none;
    transform: translateX(0);
  }
}
</style>

{% schema %}
{
  "name": "Infinite Marquee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Customers Worldwide"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Infinite scrolling marquee"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 8,
      "max": 60,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 40,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Item gap",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top margin",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom margin",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "SVG accent color",
      "default": "#d4af37"
    }
  ],
  "blocks": [
    {
      "type": "marquee_item",
      "name": "Marquee item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Image alt text",
          "default": "Marquee image"
        },
        {
          "type": "textarea",
          "id": "svg_code",
          "label": "SVG code",
          "default": "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 2l3 7h7l-5.5 4.2L18.5 21 12 16.9 5.5 21l2-7.8L2 9h7z\"/></svg>"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Premium Auto Parts"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Infinite Marquee",
      "blocks": [
        { "type": "marquee_item" },
        { "type": "marquee_item" },
        { "type": "marquee_item" }
      ]
    }
  ]
}
{% endschema %}