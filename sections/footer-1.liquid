.4-42.8z" fill="#FF6EA9"></path><path d="M503.8 294.3l-2.2 0.2v-2c0.7 0.1 1.3 0.2 2.1 0.2 0 0.6 0 1.1 0.1 1.6zM502.3 208l-0.2 28.2-1.1-27.9c0-0.5 0.6-6.6 0.6-15.8 0 9 0.6 14.9 0.7 15.5z" fill="#FF6EA9"></path><path d="M501 208.4l1.1 27.9-0.4 42.8c-127.3-16.7-153.5-72.5-153.8-73.3-11.2-23.8-8.9-51.1 6.1-73 16.1-23.5 44.3-36.9 76.4-36.9 2.8 0 5.7 0.1 8.7 0.4 17.2 1.2 31.2 8.1 41.3 20.3 18.1 21.6 21.1 55.6 21.1 75.5v0.6c0.1 9.1-0.5 15.2-0.5 15.7z" fill="#FF6EA9"></path><path d="M501.7 279l-0.1 10.3h-22c-118.3-20.8-143.1-75.5-144.1-78-13.2-28.1-10.5-60.4 7.3-86.3 20.3-29.6 56.7-45.5 97.3-42.5 21.1 1.6 38.3 10.1 50.9 25.3 8.3 10 13.8 21.9 17.5 34.1-5.6 18.6-6.8 37.4-6.8 50.1 0-19.9-3.1-53.9-21.1-75.5-10.1-12.2-24.1-19.1-41.3-20.3-2.9-0.2-5.9-0.4-8.7-0.4-32.1 0-60.3 13.4-76.4 36.9-15 21.9-17.4 49.1-6.1 73 0.1 0.8 26.4 56.6 153.6 73.3z" fill="#CE1B6D"></path><path d="M501.6 289.3v3.3c-7.7-0.9-15-2-22-3.3h22zM163.7 469.6h12.2v11.9h-12.2z" fill="#FF6EA9"></path></g></svg>
          </span> {% endcomment %}
          <span>Shopping <em>Info</em></span>
        </h3>

        <div class="cars-part-footer__line"></div>

        {% if footer_menu_2 != blank %}
          <ul class="cars-part-footer__link-list">
            {% for link in linklists[footer_menu_2].links %}
              <li>
                <a href="{{ link.url }}">
                  {% comment %} <span class="cars-part-footer__arrow">›</span> {% endcomment %}
                  <span>{{ link.title }}</span>
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

    </div>
  </div>

  <!-- Benefits Row -->
  {% if section.settings.show_benefits %}
    <div class="cars-part-footer__benefits">
      <div class="cars-part-footer__benefits-grid">
        <div class="cars-part-footer__benefit">
          <div class="cars-part-footer__benefit-icon">🚚</div>
          <div>
            <strong>{{ section.settings.benefit_1_title }}</strong>
            <span>{{ section.settings.benefit_1_text }}</span>
          </div>
        </div>

        <div class="cars-part-footer__benefit">
          <div class="cars-part-footer__benefit-icon">🛡️</div>
          <div>
            <strong>{{ section.settings.benefit_2_title }}</strong>
            <span>{{ section.settings.benefit_2_text }}</span>
          </div>
        </div>

        <div class="cars-part-footer__benefit">
          <div class="cars-part-footer__benefit-icon">↻</div>
          <div>
            <strong>{{ section.settings.benefit_3_title }}</strong>
            <span>{{ section.settings.benefit_3_text }}</span>
          </div>
        </div>

        <div class="cars-part-footer__benefit">
          <div class="cars-part-footer__benefit-icon">🎧</div>
          <div>
            <strong>{{ section.settings.benefit_4_title }}</strong>
            <span>{{ section.settings.benefit_4_text }}</span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <!-- Bottom Row -->
  <div class="cars-part-footer__bottom page-width">
    <div class="cars-part-footer__bottom-inner">
      <div class="cars-part-footer__copyright">
        {% if section.settings.copyright_text != blank %}
          {{ section.settings.copyright_text }}
        {% else %}
          © {{ 'now' | date: '%Y' }}, {{ shop.name }} Powered by Shopify
        {% endif %}
      </div>

      {% if section.settings.bottom_links_menu != blank %}
        <div class="cars-part-footer__bottom-links">
          {% for link in linklists[section.settings.bottom_links_menu].links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.show_payment_icons %}
        <div class="cars-part-footer__payments">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'cars-part-footer__payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

<style>
.cars-part-footer {
  background: #f3f3f300;
  color: #d7d7d7;
  position: relative;
  overflow: hidden;
  border-top: 1px solid #b8873c;
}

.cars-part-footer::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 85% 20%, rgba(255, 205, 110, 0.08), transparent 20%),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: auto, 80px 80px;
  pointer-events: none;
}

.cars-part-footer__top {
  padding: 55px 40px 25px;
  position: relative;
  z-index: 1;
  border-bottom: 1px solid #b8873c;
}

.cars-part-footer__grid {
  /*max-width: 1500px;*/
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.15fr 1fr 1fr 1fr;
  gap: 30px;
  align-items: start;
}

.cars-part-footer__col {
  position: relative;
  /*min-height: 280px;*/
  min-height: 322px;
  padding-right: 25px;
}

.cars-part-footer__col:not(:last-child)::after {
  content: "";
  position: absolute;
  top: 18px;
  right: 0;
  width: 1px;
  height: calc(100% - 36px);
  background: rgba(255,255,255,0.12);
}

.cars-part-footer__brand {
  /*text-align: center;*/
  padding-right: 30px;
}

/*.cars-part-footer__logo {
  margin-bottom: 22px;
}*/

.cars-part-footer__logo img {
  max-width: 170px;
  height: auto;
  display: inline-block;
}

.cars-part-footer__text {
  font-size: 15px;
  line-height: 1.7;
  color: #bfbfbf;
  max-width: 300px;
  margin: 0 auto 24px;
  margin-left: 0;
}

.cars-part-footer__social {
  display: flex;
  /*justify-content: center;*/
  gap: 14px;
  flex-wrap: wrap;
}

.cars-part-footer__social a {
  width: 42px;
  height: 42px;
  border: 1px solid #b8873c;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  text-decoration: none;
  background: rgba(255,255,255,0.02);
  transition: 0.3s ease;
}

.cars-part-footer__social a:hover {
  background: #b8873c;
  color: #000;
  transform: translateY(-2px);
}

span.cars-part-footer__social-icon svg{
    width: 24px;
    height: 24px;
}

span.cars-part-footer__social-icon {
    display: flex;
}

.cars-part-footer__heading {
  display: flex;
  align-items: center;
  gap: 14px;
  color: #000;
  font-size: 24px;
  font-weight: 700;
  margin: 0 0 20px;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.cars-part-footer__heading em {
  font-style: normal;
  color: #000;
}

.cars-part-footer__heading-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid #b8873c;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #d7a34b;
  background: rgba(183, 135, 60, 0.12);
  flex: 0 0 auto;
  font-size: 18px;
}

.cars-part-footer__line {
  width: 46px;
  height: 2px;
  background: #b8873c;
  margin: 8px 0 24px 54px;
  opacity: 0.9;
}

.cars-part-footer__contact-list,
.cars-part-footer__link-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.cars-part-footer__contact-list li {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 18px;
  font-size: 16px;
  line-height: 1.5;
}

.cars-part-footer__contact-list a,
.cars-part-footer__contact-list span,
.cars-part-footer__link-list a {
  color: #cfcfcf;
  text-decoration: none;
  transition: 0.25s ease;
}

.cars-part-footer__contact-list a:hover,
.cars-part-footer__link-list a:hover {
  color: #d7a34b;
}

.cars-part-footer__mini-icon {
  width: 34px;
  height: 34px;
  border: 1px solid #b8873c;
  border-radius: 6px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #d7a34b;
  flex: 0 0 auto;
  margin-top: 2px;
}

.cars-part-footer__link-list li {
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.cars-part-footer__link-list li a {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 0;
  font-size: 16px;
}

.cars-part-footer__arrow {
  color: #d7a34b;
  font-size: 18px;
  line-height: 1;
}

.cars-part-footer__benefits {
  border-top: 1px solid rgba(255,255,255,0.08);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  padding: 22px 40px;
  position: relative;
  z-index: 1;
}

.cars-part-footer__benefits-grid {
  /*max-width: 1500px;*/
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.cars-part-footer__benefit {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 10px 14px;
  border-right: 1px solid rgba(255,255,255,0.08);
}

.cars-part-footer__benefit:last-child {
  border-right: none;
}

.cars-part-footer__benefit-icon {
  width: 52px;
  height: 52px;
  border-radius: 12px;
  background: rgba(183, 135, 60, 0.12);
  border: 1px solid rgba(183, 135, 60, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  color: #d7a34b;
  flex: 0 0 auto;
}

.cars-part-footer__benefit strong {
  display: block;
  color: #fff;
  font-size: 16px;
  margin-bottom: 4px;
  text-transform: uppercase;
}

.cars-part-footer__benefit span {
  display: block;
  color: #b5b5b5;
  font-size: 14px;
}

.cars-part-footer__bottom {
  /*border-top: 1px solid #b8873c;*/
  padding: 18px 40px;
  position: relative;
  z-index: 1;
}

.cars-part-footer__bottom-inner {
  /*max-width: 1500px;*/
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
}

.cars-part-footer__copyright {
  font-size: 14px;
  color: #bfbfbf;
}

.cars-part-footer__bottom-links {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
}

.cars-part-footer__bottom-links a {
  color: #bfbfbf;
  text-decoration: none;
  font-size: 14px;
}

.cars-part-footer__bottom-links a:hover {
  color: #d7a34b;
}

.cars-part-footer__payments {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.cars-part-footer__payment-icon {
  height: 30px;
  width: auto;
}

@media (max-width: 1200px) {
  .cars-part-footer__grid {
    grid-template-columns: 1fr 1fr;
  }

  .cars-part-footer__col {
    min-height: auto;
  }

  .cars-part-footer__col:not(:last-child)::after {
    display: none;
  }

  .cars-part-footer__brand {
    grid-column: 1 / -1;
    text-align: left;
    padding-right: 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding-bottom: 25px;
  }

  .cars-part-footer__text,
  .cars-part-footer__social {
    justify-content: flex-start;
    margin-left: 0;
  }

  .cars-part-footer__text {
    max-width: 100%;
  }

  .cars-part-footer__line {
    margin-left: 54px;
  }

  .cars-part-footer__benefits-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .cars-part-footer__benefit:nth-child(2n) {
    border-right: none;
  }
}

@media (max-width: 768px) {
  .cars-part-footer__top,
  .cars-part-footer__benefits,
  .cars-part-footer__bottom {
    padding-left: 18px;
    padding-right: 18px;
  }

