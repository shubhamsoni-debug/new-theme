{% assign footer_menu_1 = section.settings.quick_links_menu %}
{% assign footer_menu_2 = section.settings.shopping_info_menu %}

<footer class="cars-part-footer">
  <div class="cars-part-footer__top">
    <div class="cars-part-footer__grid page-width">
      
      <!-- Brand Column -->
      <div class="cars-part-footer__col cars-part-footer__brand">
        {% if section.settings.logo != blank %}
          <div class="cars-part-footer__logo">
            <img
              src="{{ section.settings.logo | image_url: width: 260 }}"
              alt="{{ section.settings.logo_alt | escape }}"
              loading="lazy"
              width="{{ section.settings.logo.width }}"
              height="{{ section.settings.logo.height }}"
            >
          </div>
        {% endif %}

        {% if section.settings.brand_text != blank %}
          <div class="cars-part-footer__text rte">
            {{ section.settings.brand_text }}
          </div>
        {% endif %}

        {% if section.settings.show_social_icons %}
          <div class="cars-part-footer__social">
            {% if section.settings.facebook_link != blank %}
